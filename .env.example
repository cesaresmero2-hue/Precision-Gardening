# ────────────────────────────────────────────────────────────────
# Precision Gardening & Power Washing — Environment Variables
# Copy this file to .env.local for local development
# Add these as Environment Variables in your Vercel Dashboard
# ────────────────────────────────────────────────────────────────

# Required: Your Resend API key (get from https://resend.com/api-keys)
RESEND_API_KEY=re_your_api_key_here

# Required: The email address that receives notifications and OTP login codes
# This is also the ONLY email allowed to access the Admin Portal
ADMIN_EMAIL=your-admin-email@example.com

# Required: A strong random secret for signing JWTs and OTP signatures
# Generate one with: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-here-change-this-in-production

# Optional: Vercel KV (Redis) for persistent booking storage
# Leave blank to use in-memory fallback (bookings reset on cold starts)
# Get these from your Vercel Dashboard → Storage → KV Database
KV_REST_API_URL=
KV_REST_API_TOKEN=
