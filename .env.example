# ────────────────────────────────────────────────────────────────
# Precision Gardening & Power Washing — Environment Variables
# Copy this file to .env.local for local development
# Add these as Environment Variables in your Vercel Dashboard
# ────────────────────────────────────────────────────────────────

# Required: Your Resend API key (get from https://resend.com/api-keys)
RESEND_API_KEY=re_MJVwFFWd_8KUfwQq4XjhD2XTw4io2993p

# Required: The email address that receives notifications and OTP login codes
# This is also the ONLY email allowed to access the Admin Portal
ADMIN_EMAIL=cesaresmero2@gmail.com

# Optional: Secondary admin email to receive notifications (in addition to ADMIN_EMAIL)
# Leave blank if you only need one admin to receive notifications
SADMIN_EMAIL=

# Required: A strong random secret for signing JWTs and OTP signatures
# Generate one with: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-here-change-this-in-production

# Optional: Firebase Firestore configuration for persistent data storage
# These are pre-configured with defaults for the project
# Override these if you want to use a different Firebase project
# Get these from your Firebase Console → Project Settings → General
FIREBASE_PROJECT_ID=precision-gardening-f0ced
FIREBASE_API_KEY=AIzaSyCsmW2-NDmQVLjOZLfDdu2BzTh2VZHYDbM
FIREBASE_AUTH_DOMAIN=precision-gardening-f0ced.firebaseapp.com
FIREBASE_STORAGE_BUCKET=precision-gardening-f0ced.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=1007619827713
FIREBASE_APP_ID=1:1007619827713:web:263abde984297f6288f800
